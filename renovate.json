{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": ["before 5am on sunday"],
  "separateMajorMinor": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "automerge": true
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
